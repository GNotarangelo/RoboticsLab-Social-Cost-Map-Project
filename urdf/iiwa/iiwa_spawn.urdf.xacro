<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="iiwa_robot">

  <xacro:include filename="$(find social_cost_map)/urdf/iiwa/iiwa.urdf.xacro"/>

  <link name="world"/>

  <xacro:iiwa parent="world" prefix="iiwa_">
    <origin xyz="2.0 2.0 0.0" rpy="0 0 0"/>
  </xacro:iiwa>

</robot>